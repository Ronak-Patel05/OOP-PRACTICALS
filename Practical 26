class Payment
{
	void processPayment(int amount)
	{
		System.out.println("Payment of Rs."+ amount);
	}
}

class CreditCardPayment extends Payment
{
	void processPayment(int amount)
	{
		System.out.println("Payment of Rs." +amount + " done using Credit Card");
	}
}

class UPIPayment extends Payment
{
	void processPayment(int amount)
	{
		System.out.println("Payment of Rs." + amount +  "done using UPI");
	}
	public static void main(String []args)
	{
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter Amount:");
		int amt = sc. nextInt();
		System.out.println("1.Credit Card 2.UPI : ");
		int choice = sc . nextInt();
		Payment p;
		if (choice == 1)
		p = new CreditCardPayment();
		else
		p = new UPIPayment();
		
		p.processPayment(amt);
	}

